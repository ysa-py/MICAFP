{
  "name": "schedule-ooni-6h",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 */6 * * *"
            }
          ]
        }
      },
      "id": "2e760f0b-4e26-4d64-b016-14764abb2ab5",
      "name": "Schedule - every 6h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        200,
        300
      ]
    },
    {
      "parameters": {
        "command": "cd /home/user/torshield-ir && bash scripts/circleci_env_bootstrap.sh"
      },
      "id": "6484db2b-39da-49dc-827e-fecf2ee4011c",
      "name": "env-bootstrap",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        400,
        300
      ]
    },
    {
      "parameters": {
        "command": "cd /home/user/torshield-ir && set -euo pipefail\npython scripts/circleci_ooni_poller.py --depth shallow --out data/ooni_iran_snapshot.json \\\n    --dashboard data/dashboard.json --telemetry data/telemetry_state.json \\\n    2>&1 | tee logs/ooni_poll_shallow.log"
      },
      "id": "2362cabe-29c4-416e-a7ea-301bad8d66d9",
      "name": "ooni-poll (shallow)",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        600,
        300
      ]
    },
    {
      "parameters": {
        "command": "cd /home/user/torshield-ir\nif git diff --quiet --exit-code data/; then echo \"No OONI changes — nothing to commit.\"; exit 0; fi\ngit add data/ooni_iran_snapshot.json data/dashboard.json data/telemetry_state.json data/censorship_state.json logs/ooni_poll_shallow.log 2>/dev/null || true\ngit commit -m \"chore(ooni): shallow poll - $(date -u +%FT%TZ)\"\ngit pull --rebase origin \"${GIT_BRANCH:-main}\" || true\ngit push origin \"${GIT_BRANCH:-main}\""
      },
      "id": "031b0b88-cb29-4546-8efd-e7e237110005",
      "name": "commit & push snapshot",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        800,
        300
      ]
    }
  ],
  "connections": {
    "Schedule - every 6h": {
      "main": [
        [
          {
            "node": "env-bootstrap",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "env-bootstrap": {
      "main": [
        [
          {
            "node": "ooni-poll (shallow)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "ooni-poll (shallow)": {
      "main": [
        [
          {
            "node": "commit & push snapshot",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "pinData": {},
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
