# ─────────────────────────────────────────────────────────────────────────────
# v4 NEW: uTLS Evasion, Elite Registry, Circuit Breaker, Telemetry
# ALL EXISTING SETTINGS PRESERVED — NOTHING REMOVED
# ─────────────────────────────────────────────────────────────────────────────

# uTLS Evasion Layer (default: enabled)
UTLS_EVASION_MODE=true
UTLS_PROFILE_ROTATION=30

# Elite Registry: Dynamic model discovery (default: enabled)
ELITE_REGISTRY_ENABLED=true
ELITE_REGISTRY_REFRESH_HRS=6

# Circuit Breaker 11-Slot: Zero-error fallback (default: enabled)
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_MAX_FAILURES=3
CIRCUIT_BREAKER_RESET_SECS=300
SESSION_BLACKLIST_DURATION_SECS=3600

# Telemetry Watcher (default: enabled)
TELEMETRY_ENABLED=true
TELEMETRY_AUTO_DEBUG_THRESHOLD=2
TELEMETRY_LOG_MAX_MB=10

# IRST High-Censorship Hours (for time-based predictive routing)
IRST_HIGH_CENSORSHIP_START=18
IRST_HIGH_CENSORSHIP_END=1
IRST_ULTRA_STEALTH_START=20
IRST_ULTRA_STEALTH_END=23

# ─────────────────────────────────────────────────────────────────────────────
# REMEDIATION 2026-06-21: additionally discovered while building the
# cross-platform secrets manifest (docs/SECRETS_MANIFEST.md) — these keys
# are read by current provider code (12 of 14 confirmed actively used) but
# were present in NEITHER .env NOR configs/env_template.sh anywhere, on
# either side of the CI migration. Left empty here (real values can't be
# fabricated) so these provider slots are at least visible/fillable rather
# than invisibly absent.
# ─────────────────────────────────────────────────────────────────────────────
CEREBRAS_API_KEY_1=
CEREBRAS_API_KEY_2=
